{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python *)",
      "Bash(pytest *)",
      "Bash(pip install *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Read(**)",
      "Edit(agents/**)",
      "Edit(shared/**)",
      "Edit(tool_wrappers/**)",
      "Edit(skills/**)",
      "Edit(prompts/**)",
      "Edit(templates/**)",
      "Edit(data/payload_knowledge/**)",
      "Edit(tests/**)",
      "Edit(main.py)",
      "Edit(orchestrator.py)",
      "Edit(config.py)",
      "Edit(requirements.txt)",
      "Edit(CLAUDE.md)",
      "Edit(.mcp.json)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Read(.env)",
      "Read(.claude/settings.local.json)",
      "Read(data/sessions.db)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date -u +%Y-%m-%dT%H:%M:%SZ)] BASH: $CLAUDE_TOOL_INPUT\" >> .claude/audit.log 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
