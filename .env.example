# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OSINT APIs
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
SECURITYTRAILS_API_KEY=

# Metasploit RPC
MSF_RPC_HOST=127.0.0.1
MSF_RPC_PORT=55553
MSF_RPC_PASS=

# BloodHound / Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=

# OWASP ZAP
ZAP_API_KEY=
ZAP_HOST=127.0.0.1
ZAP_PORT=8080

# voicetest.dev
VOICETEST_API_KEY=

# ARGUS settings
ARGUS_MAX_RPS=30
ARGUS_DEFAULT_TIMEOUT=300
ARGUS_LOG_LEVEL=INFO
# Set to 1 to skip the authorization statement prompt (for trusted operators
# who have blanket authorization for all their engagements)
ARGUS_TRUSTED_OPERATOR=0
